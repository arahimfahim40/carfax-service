// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum request_status {
  pending
  success
  error
}

enum job_status {
  queued
  processing
  done
  failed
}

enum application_type {
  admin
  customer_portal
  client
}

model request_logs {
  id Int @id @default(autoincrement())

  method       String  @db.VarChar(10)
  path         String  @db.VarChar(255)
  query_params Json?
  request_ip   String? @db.VarChar(45)
  user_agent   String? @db.VarChar(500)

  started_at  DateTime      @default(now())
  finished_at DateTime?
  duration_ms Int?
  status      request_status @default(pending)
  http_status Int?

  vin                   String?  @db.VarChar(17)
  logged_in             Boolean?
  used_existing_session Boolean?
  mfa_triggered         Boolean?
  captcha_triggered     Boolean?

  vhr_report_id Int?
  vhr_report    vhr_reports? @relation(fields: [vhr_report_id], references: [id])

  error_code    String? @db.VarChar(64)
  error_message String?

  @@index([started_at(sort: Desc)])
  @@index([vin])
  @@index([status])
}

model vhr_reports {
  id         Int      @id @default(autoincrement())
  vin        String   @db.VarChar(17)
  created_at DateTime @default(now())

  json_payload Json

  pdf_name String @db.VarChar(255)
  pdf_url  String @db.VarChar(1000)

  user_id     Int? 
  application application_type?
  request_logs request_logs[]
  scrape_jobs scrape_jobs[]
  @@index([vin])
  @@index([created_at(sort: Desc)])
}

model scrape_jobs {
  id           String     @id @default(uuid())
  vin          String     @db.VarChar(17)
  status       job_status @default(queued)

  user_id      Int?
  application  application_type

  attempts     Int        @default(0)
  max_attempts Int        @default(3)
  next_attempt_at DateTime @default(now())

  error_code   String?    @db.VarChar(64)
  error        String?

  metadata     Json?

  callback_url           String?   @db.VarChar(1000)
  callback_attempts      Int       @default(0)
  callback_delivered_at  DateTime?
  next_callback_at       DateTime?

  vhr_report_id Int?
  vhr_report    vhr_reports? @relation(fields: [vhr_report_id], references: [id])

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([status, next_attempt_at])
  @@index([application, user_id, created_at(sort: Desc)])
  @@index([vin])
  @@index([callback_url, callback_delivered_at, next_callback_at])
}

model api_clients {
  id              Int       @id @default(autoincrement())
  application     application_type
  api_key_hash    String    @unique @db.VarChar(128)
  webhook_secret  String    @db.VarChar(128)
  revoked_at      DateTime?
  created_at      DateTime  @default(now())
  user_id         Int?
  @@index([api_key_hash])
}

model system_config {
  key        String   @id @db.VarChar(64)
  value      String?
  updated_at DateTime @updatedAt
}